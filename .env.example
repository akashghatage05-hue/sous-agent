# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Meta / WhatsApp Cloud API
WHATSAPP_TOKEN=EAAxxxxxxx          # Permanent or temporary access token from Meta App Dashboard
VERIFY_TOKEN=my_secret             # Any string you choose — must match what you set in Meta webhook settings
WHATSAPP_PHONE_NUMBER_ID=12345678  # Phone Number ID from Meta App Dashboard → WhatsApp → API Setup

# Server
PORT=3000
